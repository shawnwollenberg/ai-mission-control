MISSION_CONTROL_AGENT_TOKEN=replace-with-a-long-random-token
PUBLIC_APP_URL=http://localhost:3000
INTERNAL_AGENT_URL=
DEMO_MODE=true
EVENT_STORE=jsonl
MISSION_EVENTS_TABLE=
ENABLE_LIVE_CODEX=false
AWS_REGION=us-east-1
DEMO_EVENT_TTL_DAYS=7
DATABASE_URL=postgresql://mission_control:mission_control_local@127.0.0.1:54329/mission_control
DATABASE_POOL_SIZE=10
DATABASE_APPLICATION_NAME=mission-control-web
MISSION_CONTROL_ARTIFACT_DIR=/tmp/mission-control-artifacts
MISSION_CONTROL_OWNER_EMAIL=owner@example.com
MISSION_CONTROL_OWNER_NAME=Mission Owner
MISSION_CONTROL_OWNER_PASSWORD_HASH=replace-with-a-bcrypt-hash
MISSION_CONTROL_SESSION_SECRET=replace-with-at-least-32-random-characters
CODEX_EXECUTABLE=codex
CODEX_REPOSITORY_ROOT=/absolute/path/to/approved/repositories
CODEX_WORKTREE_ROOT=/absolute/path/to/mission-control-worktrees
ARTIFACT_STORAGE_ROOT=/absolute/path/to/mission-control-artifacts
CODEX_EXECUTION_TIMEOUT_MS=3600000
CODEX_HEARTBEAT_MS=30000
CODEX_JOB_LEASE_SECONDS=90
GIT_PROVIDER_CONFIGURATION_REFERENCE=local-config:/absolute/path/to/.config/gh
