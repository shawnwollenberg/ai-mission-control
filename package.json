{
  "name": "mission-control",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.20.0 <23"
  },
  "scripts": {
    "auth:hash": "tsx scripts/hash-password.ts",
    "dev": "next dev",
    "build": "next build",
    "db:down": "docker compose down",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:up": "docker compose up -d --wait postgres",
    "worker": "tsx scripts/worker.ts",
    "worker:codex": "tsx scripts/codex-worker.ts",
    "execution:run-codex": "tsx scripts/run-codex-execution.ts",
    "phase2:acceptance:setup": "tsx scripts/setup-phase2-acceptance.ts",
    "projections:rebuild": "tsx scripts/projections.ts",
    "projections:verify": "tsx scripts/projections.ts --verify",
    "legacy:import-dynamodb": "tsx scripts/import-dynamodb.ts",
    "start": "next start",
    "test": "node --import tsx --test tests/mission-outcome.test.mjs tests/task-state.test.mjs tests/execution-safety.test.mjs",
    "test:integration": "node --import tsx --test tests/*.integration.test.mjs",
    "test:e2e": "node --test tests/*.e2e.test.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1090.0",
    "@aws-sdk/lib-dynamodb": "^3.1090.0",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3",
    "next": "16.2.10",
    "pg": "^8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "20.14.12",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "aws-cdk": "^2.1132.0",
    "aws-cdk-lib": "^2.261.0",
    "constructs": "^10.7.0",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "5.9.3"
  },
  "overrides": {
    "postcss": "8.5.19"
  }
}
